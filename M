import { useState, useRef, useEffect } from "react";

const WELCOME_MESSAGE = `مرحباً بك في متجرنا! 🛍️

━━━━━━━━━━━━━━━━━━━━
🎧 سماعات لاسلكية — 299 ريال
بطارية 20 ساعة، جودة صوت احترافية، بلوتوث 5.0

⌚ ساعة ذكية — 499 ريال
تتبع الصحة، GPS، مقاومة للماء، بطارية 7 أيام

🎒 حقيبة ظهر جلدية — 149 ريال
جلد أصلي، 3 أحجام متاحة، ضمان سنة

🕶️ نظارة شمسية — 89 ريال
حماية UV400، إطار معدني خفيف

🔋 شاحن لاسلكي — 69 ريال
يدعم جميع الأجهزة، شحن سريع 15W
━━━━━━━━━━━━━━━━━━━━

🚚 التوصيل:
• داخل المدينة: 1-2 يوم ← 15 ريال
• خارج المدينة: 3-5 أيام ← 25 ريال
• مجاني عند الطلب فوق 300 ريال 🎁
━━━━━━━━━━━━━━━━━━━━

🛒 طريقة الطلب:
فقط أرسل لي:
1. اسمك الكامل
2. رقم هاتفك
3. عنوان التوصيل
4. المنتج والكمية

وسأحيلك فوراً لمدير المبيعات 👨‍💼

━━━━━━━━━━━━━━━━━━━━
هل تريد تقديم طلب الآن؟ 😊`;

const SYSTEM_PROMPT = `أنت مساعد مبيعات ذكي لمتجر إلكتروني. تتحدث العربية فقط. أسلوبك مهذب وواضح.

المنتجات: سماعات لاسلكية 299ر، ساعة ذكية 499ر، حقيبة ظهر 149ر، نظارة شمسية 89ر، شاحن لاسلكي 69ر.
التوصيل: داخل المدينة 15ر (1-2 يوم)، خارج المدينة 25ر (3-5 أيام)، مجاني فوق 300ر.

إذا سأل العميل أي سؤال، أجب باختصار ثم اسأله: "هل تريد تقديم طلب؟"

إذا قال نعم أو أراد الطلب:
- اجمع: الاسم، الهاتف، العنوان، المنتج والكمية — سؤال واحد في كل مرة.
- لا تكرر ما جمعته.
- بعد اكتمال المعلومات الأربع، اكتب حرفياً:

ORDER_START
الاسم: [الاسم]
الهاتف: [الهاتف]
العنوان: [العنوان]
الطلب: [المنتج والكمية]
ORDER_END

ثم قل: "تم استلام طلبك ✅ سيتواصل معك مدير المبيعات قريباً."`;

const SUGGESTIONS = [
  { text: "كم سعر السماعات؟", icon: "🎧" },
  { text: "كم يستغرق التوصيل؟", icon: "🚚" },
  { text: "ما هي المنتجات المتاحة؟", icon: "🛍️" },
  { text: "هل التوصيل مجاني؟", icon: "💰" },
];

function extractOrder(text) {
  const m = text.match(/ORDER_START\n([\s\S]*?)\nORDER_END/);
  return m ? m[1].trim() : null;
}

function cleanText(text) {
  return text.replace(/ORDER_START[\s\S]*?ORDER_END\n?/g, "").trim();
}

export default function ArabicSalesAssistant() {
  const [messages, setMessages] = useState([
    { role: "assistant", content: WELCOME_MESSAGE }
  ]);
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const [order, setOrder] = useState(null);
  const [managerEmail, setManagerEmail] = useState("manager@mystore.com");
  const [editEmail, setEditEmail] = useState(false);
  const [emailDone, setEmailDone] = useState(false);
  const bottomRef = useRef(null);
  const inputRef = useRef(null);

  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: "smooth" });
  }, [messages, loading]);

  const send = async (text) => {
    if (!text.trim() || loading) return;
    const userMsg = { role: "user", content: text.trim() };
    const history = [...messages, userMsg];
    setMessages(history);
    setInput("");
    setLoading(true);

    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          system: SYSTEM_PROMPT,
          messages: history.map((m) => ({ role: m.role, content: m.content })),
        }),
      });
      const data = await res.json();
      const raw = data.content?.map((b) => b.text || "").join("") || "عذراً، حدث خطأ. حاول مجدداً.";
      const orderData = extractOrder(raw);
      const display = cleanText(raw);
      if (orderData) setOrder(orderData);
      setMessages((prev) => [...prev, { role: "assistant", content: display }]);
    } catch {
      setMessages((prev) => [...prev, { role: "assistant", content: "عذراً، لم أتمكن من الاتصال. حاول مجدداً." }]);
    } finally {
      setLoading(false);
      inputRef.current?.focus();
    }
  };

  const sendEmail = () => {
    const subject = encodeURIComponent("طلب جديد من المتجر");
    const body = encodeURIComponent(`تفاصيل الطلب الجديد:\n\n${order}\n\n—\nأُرسل من نظام المساعد الذكي`);
    window.open(`mailto:${managerEmail}?subject=${subject}&body=${body}`);
    setEmailDone(true);
  };

  const reset = () => {
    setMessages([{ role: "assistant", content: WELCOME_MESSAGE }]);
    setOrder(null);
    setEmailDone(false);
  };

  return (
    <div style={{
      minHeight: "100vh",
      background: "#0a0a0f",
      display: "flex",
      alignItems: "center",
      justifyContent: "center",
      padding: 16,
      fontFamily: "'Segoe UI', Tahoma, Arial, sans-serif",
      direction: "rtl",
    }}>
      <div style={{ width: "100%", maxWidth: 500, display: "flex", flexDirection: "column", gap: 12 }}>

        {/* Header */}
        <div style={{
          background: "linear-gradient(135deg, #1a1a2e 0%, #16213e 100%)",
          border: "1px solid rgba(255,180,0,0.2)",
          borderRadius: 18,
          padding: "14px 18px",
          display: "flex",
          alignItems: "center",
          justifyContent: "space-between",
        }}>
          <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
            <div style={{
              width: 44, height: 44, borderRadius: 14,
              background: "linear-gradient(135deg, #f59e0b, #d97706)",
              display: "flex", alignItems: "center", justifyContent: "center",
              fontSize: 22,
            }}>🛒</div>
            <div>
              <div style={{ color: "#fbbf24", fontWeight: 700, fontSize: 15 }}>مساعد المتجر الذكي</div>
              <div style={{ display: "flex", alignItems: "center", gap: 5, flexDirection: "row-reverse", justifyContent: "flex-end" }}>
                <span style={{ color: "#4ade80", fontSize: 11 }}>متصل الآن</span>
                <div style={{ width: 6, height: 6, borderRadius: "50%", background: "#4ade80" }} />
              </div>
            </div>
          </div>
          <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
            {editEmail ? (
              <input
                defaultValue={managerEmail}
                onBlur={(e) => { setManagerEmail(e.target.value); setEditEmail(false); }}
                onKeyDown={(e) => { if (e.key === "Enter") { setManagerEmail(e.target.value); setEditEmail(false); } }}
                autoFocus
                style={{
                  background: "rgba(255,255,255,0.08)", border: "1px solid rgba(251,191,36,0.4)",
                  borderRadius: 8, color: "#fbbf24", padding: "4px 10px", fontSize: 12,
                  outline: "none", width: 190, direction: "ltr", textAlign: "left",
                }}
              />
            ) : (
              <button onClick={() => setEditEmail(true)} style={{
                background: "rgba(251,191,36,0.08)", border: "1px solid rgba(251,191,36,0.2)",
                borderRadius: 8, color: "#fbbf24", fontSize: 11, padding: "4px 10px", cursor: "pointer",
                direction: "ltr",
              }}>
                ✉ {managerEmail}
              </button>
            )}
            {messages.length > 0 && (
              <button onClick={reset} title="محادثة جديدة" style={{
                background: "rgba(255,255,255,0.06)", border: "1px solid rgba(255,255,255,0.1)",
                borderRadius: 8, color: "#94a3b8", fontSize: 14, padding: "4px 10px", cursor: "pointer",
              }}>↺</button>
            )}
          </div>
        </div>

        {/* Chat */}
        <div style={{
          background: "#0f0f1a",
          border: "1px solid rgba(255,255,255,0.06)",
          borderRadius: 18,
          overflow: "hidden",
          display: "flex",
          flexDirection: "column",
        }}>
          <div style={{
            height: 420, overflowY: "auto", padding: 18,
            display: "flex", flexDirection: "column", gap: 12,
            scrollbarWidth: "none",
          }}>

            {/* Messages */}
            {messages.map((m, i) => (
              <div key={i} style={{
                display: "flex",
                flexDirection: m.role === "user" ? "row" : "row-reverse",
                gap: 8, alignItems: "flex-end",
              }}>
                {m.role === "assistant" && (
                  <div style={{
                    width: 30, height: 30, borderRadius: "50%", flexShrink: 0,
                    background: "linear-gradient(135deg, #f59e0b, #d97706)",
                    display: "flex", alignItems: "center", justifyContent: "center", fontSize: 15,
                  }}>🛒</div>
                )}
                <div style={{
                  maxWidth: "78%",
                  background: m.role === "user"
                    ? "linear-gradient(135deg, #d97706, #b45309)"
                    : "rgba(255,255,255,0.05)",
                  border: m.role === "assistant" ? "1px solid rgba(255,255,255,0.07)" : "none",
                  borderRadius: m.role === "user" ? "18px 18px 18px 4px" : "18px 18px 4px 18px",
                  padding: "10px 14px",
                  color: "#f1f5f9",
                  fontSize: 13.5, lineHeight: 1.7,
                  whiteSpace: "pre-wrap",
                  textAlign: "right",
                }}>
                  {m.content}
                </div>
              </div>
            ))}

            {/* Loading dots */}
            {loading && (
              <div style={{ display: "flex", flexDirection: "row-reverse", gap: 8, alignItems: "flex-end" }}>
                <div style={{
                  width: 30, height: 30, borderRadius: "50%",
                  background: "linear-gradient(135deg, #f59e0b, #d97706)",
                  display: "flex", alignItems: "center", justifyContent: "center", fontSize: 15,
                }}>🛒</div>
                <div style={{
                  background: "rgba(255,255,255,0.05)",
                  border: "1px solid rgba(255,255,255,0.07)",
                  borderRadius: "18px 18px 4px 18px",
                  padding: "12px 16px",
                  display: "flex", gap: 5, alignItems: "center",
                }}>
                  {[0, 1, 2].map((n) => (
                    <div key={n} style={{
                      width: 7, height: 7, borderRadius: "50%", background: "#f59e0b",
                      animation: "pulse 1.2s infinite", animationDelay: `${n * 0.2}s`,
                    }} />
                  ))}
                </div>
              </div>
            )}
            <div ref={bottomRef} />
          </div>

          {/* Input */}
          <div style={{
            padding: "12px 14px",
            borderTop: "1px solid rgba(255,255,255,0.05)",
            display: "flex", gap: 8,
          }}>
            <button
              onClick={() => send(input)}
              disabled={loading || !input.trim()}
              style={{
                background: loading || !input.trim()
                  ? "rgba(245,158,11,0.2)"
                  : "linear-gradient(135deg, #f59e0b, #d97706)",
                border: "none", borderRadius: 12,
                width: 44, height: 44, flexShrink: 0,
                cursor: loading || !input.trim() ? "not-allowed" : "pointer",
                display: "flex", alignItems: "center", justifyContent: "center",
                fontSize: 18, transition: "all 0.2s",
              }}
            >←</button>
            <input
              ref={inputRef}
              value={input}
              onChange={(e) => setInput(e.target.value)}
              onKeyDown={(e) => { if (e.key === "Enter") { e.preventDefault(); send(input); } }}
              placeholder="اكتب سؤالك هنا..."
              disabled={loading}
              style={{
                flex: 1, background: "rgba(255,255,255,0.05)",
                border: "1px solid rgba(255,255,255,0.08)",
                borderRadius: 12, padding: "10px 14px",
                color: "#f1f5f9", fontSize: 13.5, outline: "none",
                textAlign: "right",
              }}
            />
          </div>
        </div>

        {/* Order Card */}
        {order && (
          <div style={{
            background: "linear-gradient(135deg, rgba(34,197,94,0.05), rgba(16,185,129,0.05))",
            border: "1px solid rgba(74,222,128,0.3)",
            borderRadius: 18, padding: "16px 20px",
          }}>
            <div style={{ color: "#4ade80", fontWeight: 700, fontSize: 13, marginBottom: 10 }}>
              ✅ تفاصيل الطلب — جاهز للإرسال
            </div>
            <pre style={{
              color: "#a7f3d0", fontSize: 13, lineHeight: 1.8,
              margin: "0 0 14px 0", fontFamily: "inherit",
              whiteSpace: "pre-wrap", textAlign: "right",
            }}>{order}</pre>

            {!emailDone ? (
              <button onClick={sendEmail} style={{
                background: "linear-gradient(135deg, #16a34a, #15803d)",
                border: "none", borderRadius: 12,
                color: "#fff", fontWeight: 700, fontSize: 13.5,
                padding: "11px 20px", cursor: "pointer", width: "100%",
              }}>
                📧 إرسال الطلب للمدير ({managerEmail})
              </button>
            ) : (
              <div style={{
                background: "rgba(74,222,128,0.1)", borderRadius: 12,
                padding: 10, textAlign: "center",
                color: "#4ade80", fontWeight: 700, fontSize: 13,
              }}>
                ✓ تم فتح تطبيق الإيميل — الطلب جاهز للإرسال!
              </div>
            )}
          </div>
        )}

        <div style={{ textAlign: "center", color: "rgba(255,255,255,0.18)", fontSize: 11 }}>
          مشغّل بواسطة Claude · اضغط على الإيميل لتغييره
        </div>
      </div>

      <style>{`
        @keyframes pulse {
          0%, 80%, 100% { transform: scale(0.8); opacity: 0.4; }
          40% { transform: scale(1.2); opacity: 1; }
        }
        input::placeholder { color: rgba(255,255,255,0.2); }
        ::-webkit-scrollbar { display: none; }
      `}</style>
    </div>
  );
}
