<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <title>متجر الأجهزة الإلكترونية - ملاك شوب</title>
  <style>
    body {
      font-family: Arial;
      margin: 0;
      background: #f4f6f8;
    }

    header {
      background: #111;
      color: white;
      padding: 15px;
      text-align: center;
    }

    .products {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      padding: 20px;
    }

    .card {
      background: white;
      padding: 15px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    .chatbot {
      position: fixed;
      bottom: 20px;
      left: 20px;
      width: 300px;
      background: white;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.2);
      overflow: hidden;
    }

    .chat-header {
      background: #222;
      color: white;
      padding: 10px;
    }

    .chat-body {
      height: 300px;
      overflow-y: auto;
      padding: 10px;
      font-size: 14px;
    }

    .chat-input {
      display: flex;
      border-top: 1px solid #ddd;
    }

    .chat-input input {
      flex: 1;
      padding: 10px;
      border: none;
    }

    .chat-input button {
      padding: 10px;
      background: #111;
      color: white;
      border: none;
    }
  </style>
</head>

<body>

<header>
  <h1>🛍️ ملاك شوب - متجر الأجهزة الإلكترونية</h1>
</header>

<div class="products">
  <div class="card">📱 هاتف ذكي - 300$</div>
  <div class="card">💻 حاسوب محمول - 800$</div>
  <div class="card">🎧 سماعات - 50$</div>
</div>

<!-- Chatbot -->
<div class="chatbot">
  <div class="chat-header">🤖 مساعد المتجر</div>
  <div class="chat-body" id="chat"></div>

  <div class="chat-input">
    <input id="msg" placeholder="اكتب هنا..." />
    <button onclick="send()">إرسال</button>
  </div>
</div>

<script>
let step = 0;
let order = {};

const chat = document.getElementById("chat");

function bot(text){
  chat.innerHTML += `<div><b>البوت:</b> ${text}</div>`;
  chat.scrollTop = chat.scrollHeight;
}

function user(text){
  chat.innerHTML += `<div><b>أنت:</b> ${text}</div>`;
  chat.scrollTop = chat.scrollHeight;
}

bot(`مرحباً بك في ملاك شوب 🛍️
لدينا هواتف، حواسيب، وسماعات.
هل تريد طلب منتج؟ (نعم / لا)`);

function send(){
  let input = document.getElementById("msg");
  let text = input.value;
  input.value = "";
  user(text);

  if(step === 0){
    if(text === "نعم"){
      bot("ممتاز 👍 ما هو المنتج الذي تريد شراؤه؟");
      step = 1;
    } else {
      bot("حسناً، إذا احتجت شيئاً أنا هنا 👋");
    }
  }

  else if(step === 1){
    order.product = text;
    bot("اكتب اسمك الكامل:");
    step = 2;
  }

  else if(step === 2){
    order.name = text;
    bot("اكتب رقم الهاتف:");
    step = 3;
  }

  else if(step === 3){
    order.phone = text;
    bot(`تلخيص الطلب:
📦 ${order.product}
👤 ${order.name}
📞 ${order.phone}

هل أنت متأكد؟ (نعم / لا)`);
    step = 4;
  }

  else if(step === 4){
    if(text === "نعم"){
      bot("تم إرسال طلبك بنجاح ✅ سيتم التواصل معك قريباً");

      // إرسال إلى السيرفر
      fetch("http://localhost:3000/order", {
        method: "POST",
        headers: {"Content-Type":"application/json"},
        body: JSON.stringify(order)
      });

    } else {
      bot("تم إلغاء الطلب ❌");
    }
  }
}
</script>

</body>
</html>
